{
  "name": "pilotnow",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:push": "pnpm --filter @pilotnow/db db:push",
    "db:studio": "pnpm --filter @pilotnow/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.10.0",
    "typescript": "^5.8.0"
  }
}
