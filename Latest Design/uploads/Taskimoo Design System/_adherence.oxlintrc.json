        "message": "<Tabs> doesn't accept that prop. Declared props: items, value, defaultValue, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='TaskTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|red|key|ref|className|style|children)$/]",
        "message": "<TaskTag> doesn't accept that prop. Declared props: label, red."
