        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|defaultValue|placeholder|rows|hint|invalid|disabled|id|name|onChange|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, value, defaultValue, placeholder, rows, hint, invalid, disabled, id, name, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|message|icon|action|onDismiss|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: tone, title, message, icon, action, onDismiss."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|success|danger|warning|info)$/]",
        "message": "<Toast> tone must be one of 'default' | 'success' | 'danger' | 'warning' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|description|checked|defaultChecked|disabled|red|size|id|name|onChange|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: label, description, checked, defaultChecked, disabled, red, size, id, name, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Toggle> size must be one of 'sm' | 'md'."
      }
    ]
  },
