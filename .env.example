# Postgres (docker-compose up -d)
DATABASE_URL=postgres://pilotnow:pilotnow@localhost:5432/pilotnow

# Hono Web API
API_PORT=4000

# apps/web → same-origin API proxy
NEXT_PUBLIC_API_URL=https://pilotnow-api.singaporetestlab.com

# apps/mcp → API base URL + agent credential (FR-035: agents use their own identity)
PILOTNOW_API_URL=http://localhost:4000
PILOTNOW_AGENT_TOKEN=dev-agent-token

# Password-reset email (required in production; local development returns a test code in the response)
RESEND_API_KEY=
PASSWORD_RESET_FROM_EMAIL=PilotNow <no-reply@example.com>
