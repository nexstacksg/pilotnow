# Postgres (docker-compose up -d)
DATABASE_URL=postgres://pilotnow:pilotnow@localhost:5432/pilotnow

# Hono Web API
API_PORT=4000

# apps/web → same-origin API proxy
NEXT_PUBLIC_API_URL=/api
PILOTNOW_WEB_API_URL=http://localhost:4000

# Bootstrap admin (created on first login if admin_users is empty)
PILOTNOW_ADMIN_EMAIL=admin@gmail.com
PILOTNOW_ADMIN_PASSWORD=User123***
PILOTNOW_ADMIN_NAME=PilotNow Admin

# apps/mcp → API base URL + agent credential (FR-035: agents use their own identity)
PILOTNOW_API_URL=http://localhost:4000
PILOTNOW_AGENT_TOKEN=dev-agent-token
PILOTNOW_OFFICER_LINK_SECRET=dev-officer-link-secret

# Password-reset email via Resend SMTP 
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=true

# DigitalOcean Spaces
DO_SPACES_ACCESS_KEY=
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=
DO_SPACES_REGION=
DO_SPACES_CDN=
DO_SPACES_ROOT_PATH=
DO_SPACES_SECRET_KEY=
